LOAD CATALOG FROM "data/hgnc_interleukins.csv";
LOAD NETWORK FROM "data/th17_network.csv";
LOAD RULES FROM "rules/th17_core.icirc";

SET IL6 = HIGH;
SET IL23A = HIGH;
SET TGFB1 = MODERATE;
SET IL10 = LOW;
SET TNF = HIGH;
SET IL36G = HIGH;
SET IL37 = LOW;

RUN 3 STEPS;

EXPLAIN Th17;
EXPLAIN RORC;
EXPLAIN NFkB;
RANK NODES BY SCORE DESC LIMIT 10;
FIND FEEDBACK_LOOPS;
REPORT UNMODELED_GENES;
